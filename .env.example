# Copy to .env on HPC (never commit .env)

# Hugging Face token — required for gated models / faster downloads
# HF_TOKEN=hf_...

# Local model paths on HPC scratch
QREASON_MODEL_QWEN7B=/scratch/$USER/reasoning-compression-lab/models/DeepSeek-R1-Distill-Qwen-7B
