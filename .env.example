# Copy to .env on HPC (never commit .env)

# Hugging Face token — required for gated models / faster downloads
# HF_TOKEN=hf_...

# PARAM Rudra scratch paths
QR=/scratch/$USER/reasoning-compression-lab
QREASON_MODEL_QWEN7B=/scratch/$USER/reasoning-compression-lab/models/DeepSeek-R1-Distill-Qwen-7B
# QREASON_MODEL_QWEN7B_GPTQ4=/scratch/$USER/reasoning-compression-lab/models/DeepSeek-R1-Distill-Qwen-7B-GPTQ-4

# Hugging Face cache on scratch (also set by scripts/hpc/param_rudra_env.sh)
HF_HOME=/scratch/$USER/reasoning-compression-lab/hf_cache
HF_HUB_CACHE=/scratch/$USER/reasoning-compression-lab/hf_cache/hub
HF_DATASETS_CACHE=/scratch/$USER/reasoning-compression-lab/hf_cache/datasets

# PARAM Rudra conda (optional override)
# CONDA_ROOT=/home/apps/MSCC/miniconda3
