{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "raw_response.v1.json",
  "title": "Raw inference row (V8.2 §11.1)",
  "type": "object",
  "required": [
    "id",
    "prompt",
    "completion",
    "cell_id",
    "task",
    "seed",
    "run_id",
    "git_commit",
    "config_hash",
    "prompt_template_version"
  ],
  "properties": {
    "run_id": { "type": "string" },
    "timestamp": { "type": "string" },
    "git_commit": { "type": "string" },
    "config_hash": { "type": "string" },
    "model_revision": { "type": ["string", "null"] },
    "dataset_revision": { "type": ["string", "null"] },
    "prompt_template_version": { "type": "string" },
    "prompt_template_file": { "type": "string" },
    "input_text_hash": { "type": "string" },
    "id": { "type": ["string", "integer"] },
    "problem": { "type": "string" },
    "gold_solution": { "type": "string" },
    "gold_letter": { "type": "string" },
    "prompt": { "type": "string" },
    "completion": { "type": "string" },
    "finish_reason": { "type": ["string", "null"] },
    "truncated": { "type": ["boolean", "null"] },
    "prompt_tokens": { "type": ["integer", "null"] },
    "completion_tokens": { "type": ["integer", "null"] },
    "latency_sec": { "type": ["number", "null"] },
    "time_to_first_token_sec": { "type": ["number", "null"] },
    "peak_vram_gb": { "type": ["number", "null"] },
    "cell_id": { "type": "string" },
    "quant_config": { "type": "string" },
    "task": { "type": "string" },
    "seed": { "type": "integer" },
    "backend_version": { "type": ["string", "null"] },
    "decoding_temperature": { "type": ["number", "null"] },
    "decoding_top_p": { "type": ["number", "null"] },
    "decoding_max_tokens": { "type": ["integer", "null"] },
    "decoding_repetition_penalty": { "type": ["number", "null"] }
  },
  "additionalProperties": true
}
